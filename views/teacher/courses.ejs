<%- include('../partials/teacher-header', { title: 'My Courses', user }) %>
<h1>My Courses</h1>
<p><a href="/courses/new" class="btn">New Course</a></p>

<% if (courses.length === 0) { %>
<p>No courses yet.</p>
<% } else { %>
<div class="course-accordion reorderable-list" data-reorder-url="/api/courses/reorder">
<% courses.forEach(function(c, idx) { %>
    <details class="course-details" id="course-<%= c.id %>" data-id="<%= c.id %>">
        <summary class="course-summary">
            <span class="reorderable-handle" title="Drag to reorder" aria-label="Drag to reorder">⋮⋮</span>
            <span class="course-order" data-prefix=""><%= (c.sort_order != null ? c.sort_order : idx) + 1 %></span>
            <button
                type="button"
                class="btn btn-small copy-id-btn"
                data-copy-text="/api/course/<%= c.id %>"
                aria-label="Copy course API call to clipboard"
                title="Copy course API call to clipboard"
                onclick="event.stopPropagation();"
            >
                ⧉
            </button>
            <span class="course-name"><%= c.name %></span>
        </summary>

        <div class="course-content">
            <ul class="links">
                <li><strong><a href="/courses/<%= c.id %>/tasks">Tasks</a></strong> (<%= c.taskCount %>)</li>
                <li><strong><a href="/courses/<%= c.id %>/units">Units</a></strong> (<%= c.unitCount %>)</li>
                <li><strong><a href="/courses/<%= c.id %>/vocab">Vocabulary</a></strong> (<%= c.vocabCount %>)</li>
                <li><strong><a href="/courses/<%= c.id %>/quizzes">Quizzes</a></strong> (<%= c.quizCount %>)</li>
                <li><strong><a href="/courses/<%= c.id %>/questions">Questions</a></strong> (<%= c.goodQuestionCount || 0 %>)</li>
                <li><strong><a href="/courses/<%= c.id %>/import">Import from Excel/CSV</a></strong></li>
                <li><strong><a href="/courses/<%= c.id %>/export-template" onclick="event.stopPropagation()">Export to Excel</a></strong></li>
            </ul>

            <form method="post" action="/courses/<%= c.id %>" class="course-edit-form">
                <div class="field-row">
                    <label>Name <input type="text" name="name" value="<%= c.name %>" required /></label>
                    <button type="submit" class="btn btn-small">Save</button>
                </div>
                <!-- <label style="margin-top: 0.5rem;"><input type="checkbox" name="is_public" value="1" <%= c.is_public ? 'checked' : '' %> /> Public</label> -->
            </form>
            <form method="post"
                  action="/courses/<%= c.id %>/delete"
                  style="margin-top:0.5rem;"
                  onsubmit="return confirm('Delete this course and all of its units, tasks, vocab, and quizzes? This cannot be undone.');">
                <button type="submit" class="btn btn-small btn-danger">Delete course</button>
            </form>
        </div>
    </details>
<% }); %>
</div>
<% } %>

<script>
(function() {
    var hash = window.location.hash;
    if (hash && hash.indexOf('course-') === 1) {
        var el = document.getElementById(hash.slice(1));
        if (el && el.tagName === 'DETAILS') el.setAttribute('open', '');
    }
})();
</script>

<%- include('../partials/footer') %>