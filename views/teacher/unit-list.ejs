<%- include('../partials/teacher-header', { title: 'Units - ' + course.name, user, course }) %>
<h1>Units</h1>
<p><a href="/courses/<%= course.id %>/units/new" class="btn">New Unit</a> <a href="/courses#course-<%= course.id %>" class="btn btn-secondary">Back to courses</a></p>
<% if (units.length === 0) { %>
<p>No units. <a href="/courses/<%= course.id %>/units/new">Add one</a>.</p>
<% } else { %>
<div class="unit-accordion reorderable-list" data-reorder-url="/api/courses/<%= course.id %>/units/reorder">
<% units.forEach(function(u) { %>
    <details class="unit-details" id="unit-<%= u.id %>" data-id="<%= u.id %>">
        <summary class="unit-summary">
            <span class="reorderable-handle" title="Drag to reorder" aria-label="Drag to reorder">⋮⋮</span>
            <span class="unit-order" data-prefix="Unit "><%= u.sort_order + 1 %></span>
            <button
                type="button"
                class="btn btn-small copy-id-btn"
                data-copy-text="/api/unit/<%= u.id %>"
                aria-label="Copy unit API call to clipboard"
                title="Copy unit API call to clipboard"
                onclick="event.stopPropagation();"
            >
                ⧉
            </button>
            <span class="unit-name"><%= u.name %></span>
            <span class="unit-meta"><%= u.unitTasks.length %> task<%= u.unitTasks.length !== 1 ? 's' : '' %>, <%= u.unitVocab.length %> vocab term<%= u.unitVocab.length !== 1 ? 's' : '' %></span>
        </summary>
        <div class="unit-content">
            <form method="post" action="/courses/<%= course.id %>/units/<%= u.id %>" class="unit-name-form field-row">
                <label>Unit name <input type="text" name="name" value="<%= u.name %>" required /></label>
                <button type="submit" class="btn btn-small">Save name</button>
            </form>
            <form method="post"
                  action="/courses/<%= course.id %>/units/<%= u.id %>/delete"
                  style="margin:0.5rem 0 0.75rem 0;">
                <button type="submit"
                        class="btn btn-small btn-danger"
                        onclick="return confirm('Delete this unit and its task/vocab associations? This cannot be undone.');">
                    Delete unit
                </button>
            </form>

            <h3>Tasks in this unit</h3>
            <% if (u.unitTasks.length > 0) { %>
            <table data-reorder-url="/api/courses/<%= course.id %>/units/<%= u.id %>/tasks/reorder">
                <thead><tr><th>Task #</th><th>Task</th><th>Actions</th></tr></thead>
                <tbody>
                <% u.unitTasks.forEach(function(t) { %>
                    <tr data-id="<%= t.task_id %>">
                        <td><%= (t.task_sort_order != null ? t.task_sort_order : 0) + 1 %></td>
                        <td><a href="/courses/<%= course.id %>/tasks/<%= t.task_id %>"><%= t.name %></a></td>
                        <td>
                            <form method="post"
                                  action="/courses/<%= course.id %>/units/<%= u.id %>/tasks/<%= t.task_id %>/remove"
                                  style="display:inline;">
                                <button type="submit"
                                        class="btn btn-small btn-danger"
                                        onclick="return confirm('Remove this task from the unit? The task itself will not be deleted.');">
                                    Remove
                                </button>
                            </form>
                        </td>
                    </tr>
                <% }); %>
                </tbody>
            </table>
            <% } else { %>
            <p class="text-muted">No tasks in this unit.</p>
            <% } %>
            <% if (u.allTasksAvailable && u.allTasksAvailable.length > 0) { %>
            <form method="post" action="/courses/<%= course.id %>/units/<%= u.id %>/tasks" class="inline-form">
                <label>Add task <select name="task_id"><option value="">-- Select --</option><% u.allTasksAvailable.forEach(function(t) { %><option value="<%= t.id %>"><%= t.name %></option><% }); %></select></label>
                <button type="submit" class="btn btn-small">Add</button>
            </form>
            <% } %>

            <h3>Vocabulary in this unit</h3>
            <% if (u.unitVocab.length > 0) { %>
            <table data-reorder-url="/api/courses/<%= course.id %>/units/<%= u.id %>/vocab/reorder">
                <thead><tr><th>Term</th><th>Definition</th><th>Actions</th></tr></thead>
                <tbody>
                <% u.unitVocab.forEach(function(v) { %>
                    <tr data-id="<%= v.vocab_term_id %>">
                        <td><%= v.term %></td>
                        <td><%= v.definition || '—' %></td>
                        <td>
                            <form method="post"
                                  action="/courses/<%= course.id %>/units/<%= u.id %>/vocab/<%= v.vocab_term_id %>/remove"
                                  style="display:inline;">
                                <button type="submit"
                                        class="btn btn-small btn-danger"
                                        onclick="return confirm('Remove this vocab term from the unit? The term will remain in the course.');">
                                    Remove
                                </button>
                            </form>
                        </td>
                    </tr>
                <% }); %>
                </tbody>
            </table>
            <% } else { %>
            <p class="text-muted">No vocabulary in this unit.</p>
            <% } %>
            <% if (u.allVocabAvailable && u.allVocabAvailable.length > 0) { %>
            <form method="post" action="/courses/<%= course.id %>/units/<%= u.id %>/vocab" class="inline-form">
                <label>Add vocab <select name="vocab_term_id"><option value="">-- Select --</option><% u.allVocabAvailable.forEach(function(v) { %><option value="<%= v.id %>"><%= v.term %></option><% }); %></select></label>
                <button type="submit" class="btn btn-small">Add</button>
            </form>
            <% } %>
        </div>
    </details>
<% }); %>
</div>
<% } %>
<script>
(function() {
    var hash = window.location.hash;
    if (hash && hash.indexOf('unit-') === 1) {
        var el = document.getElementById(hash.slice(1));
        if (el && el.tagName === 'DETAILS') el.setAttribute('open', '');
    }
})();
</script>
<%- include('../partials/footer') %>
